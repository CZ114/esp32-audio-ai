# OpenAI API配置
# 到 https://platform.openai.com 获取API Key
OPENAI_API_KEY=sk-your-api-key-here

# 使用本地Whisper模型 (免费)
# true: 使用本地模型, false: 使用API
USE_LOCAL_MODEL=true

# 本地模型大小
# tiny: 39MB, base: 74MB, small: 244MB, medium: 769MB, large: 1550MB
MODEL_SIZE=base

# 音频配置
SAMPLE_RATE=16000
VAD_THRESHOLD=500

# 输出配置
OUTPUT_DIR=output